# Database
DB_HOST=localhost
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=swap_service
DB_PORT=5432
DB_SSLMODE=disable

# Server
PORT=8080
GIN_MODE=debug

# Geocoding (Mapbox API)
# Obtén tu token en https://account.mapbox.com/
# El free tier incluye 100,000 requests/mes
GEO_API=your_mapbox_token_here

# Cloudinary (optional)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
