{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "baseUrl": ".",
    "paths": {
      "@/*": ["./*"],
      "@Global/*": ["./src/Global/*"],
      "@APP/*": ["./src/APP/*"],
      "@Web/*": ["./src/Web/*"],
      "@backend/*": ["./backend/*"]
    }
  },
  "include": [
    "**/*.ts",
    "**/*.tsx",
    ".expo/types/**/*.ts",
    "expo-env.d.ts"
  ]
}
